{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "liquid-image",
  "version": "0.1.0",
  "identifier": "vn.io.weback1609.liquid-image",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "liquid-image",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "center": true,
        "visible": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "/tmp/liquid-image-preview/*",
          "$TMP/liquid-image-preview/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/magick"]
  }
}
